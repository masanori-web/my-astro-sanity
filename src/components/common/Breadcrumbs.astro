---
interface Item {
  label: string;
  href?: string;
}

interface Props {
  items: Item[];
}

const { items } = Astro.props;
---

<nav aria-label="Breadcrumb" class="breadcrumbs">
  <ol>
    <li><a href="/">ホーム</a></li>
    {items.map((item) => (
      <li>
        {item.href ? <a href={item.href}>{item.label}</a> : <span>{item.label}</span>}
      </li>
    ))}
  </ol>
</nav>

<style>
  .breadcrumbs {
    margin-bottom: 18px;
  }

  .breadcrumbs ol {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    list-style: none;
    padding: 0;
    margin: 0;
    color: var(--color-muted);
    font-size: 14px;
  }

  .breadcrumbs li:not(:last-child)::after {
    content: "/";
    margin-left: 10px;
  }
</style>
