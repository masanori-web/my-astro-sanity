---
interface Props {
  title: string;
  body: string;
  primaryHref: string;
  primaryLabel: string;
  secondaryHref?: string;
  secondaryLabel?: string;
}

const { title, body, primaryHref, primaryLabel, secondaryHref, secondaryLabel } = Astro.props;
---

<section class="page-section">
  <div class="container">
    <div class="cta surface">
      <div>
        <div class="eyebrow">Contact</div>
        <h2>{title}</h2>
        <p>{body}</p>
      </div>

      <div class="button-row">
        <a class="button button-primary" href={primaryHref}>{primaryLabel}</a>
        {secondaryHref && secondaryLabel && (
          <a class="button button-secondary" href={secondaryHref}>{secondaryLabel}</a>
        )}
      </div>
    </div>
  </div>
</section>

<style>
  .cta {
    padding: 32px;
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 20px;
    background: linear-gradient(135deg, #13233c, #17699c);
    color: #fff;
  }

  .cta h2 {
    margin: 16px 0 12px;
    font-size: clamp(30px, 4vw, 50px);
    line-height: 1.02;
    letter-spacing: -0.05em;
  }

  .cta p {
    max-width: 640px;
    margin: 0;
    color: rgba(255, 255, 255, 0.76);
    line-height: 1.8;
  }

  .cta .button-primary {
    background: #fff;
    color: #13233c;
  }

  .cta .button-secondary {
    border-color: rgba(255, 255, 255, 0.28);
    color: #fff;
    background: transparent;
  }

  @media (max-width: 960px) {
    .cta {
      flex-direction: column;
      align-items: start;
    }
  }
</style>
