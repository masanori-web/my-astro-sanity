---
import type { Department } from "../../lib/sanity/types";

interface Props {
  department: Department;
}

const { department } = Astro.props;
---

<article class="department-card">
  <div class="department-meta">
    <span class="chip">{department.postCount} 件</span>
  </div>
  <h3><a href={`/departments/${department.slug}/`}>{department.title}</a></h3>
  <p>{department.description}</p>
  {department.latestPost && (
    <a class="latest" href={`/news/${department.latestPost.slug}/`}>
      関連記事: {department.latestPost.title}
    </a>
  )}
</article>

<style>
  .department-card {
    padding: 24px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: rgba(255, 255, 255, 0.88);
  }

  .department-meta {
    margin-bottom: 12px;
  }

  .chip {
    display: inline-flex;
    padding: 7px 12px;
    border-radius: 999px;
    background: var(--color-accent-soft);
    color: var(--color-accent);
    font-size: 12px;
    font-weight: 700;
  }

  .department-card h3 {
    margin: 0 0 12px;
    font-size: 26px;
  }

  .department-card p {
    margin: 0;
    color: var(--color-muted);
    line-height: 1.8;
  }

  .latest {
    display: inline-block;
    margin-top: 18px;
    color: var(--color-primary);
    font-weight: 700;
  }
</style>
