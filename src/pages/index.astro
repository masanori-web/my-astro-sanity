---
import { client } from "../lib/sanityClient";
import { PortableText } from "@portabletext/react";
import { createImageUrlBuilder } from "@sanity/image-url";
import React from "react";

const builder = createImageUrlBuilder(client);

function urlFor(source) {
  return builder.image(source);
}

const portableTextComponents = {
  types: {
    image: ({ value }) =>
      React.createElement("img", {
        src: urlFor(value).width(1200).height(900).fit("max").url(),
        alt: value.alt ?? "",
      }),
  },
};

const posts = await client.fetch(`
*[_type == "post"]
| order(_createdAt desc)
{
  _id,
  title,
  body,
  mainImage
}
`);

const featuredPost = posts[0];
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Cyber Blog</title>
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@500;700&family=Zen+Kaku+Gothic+New:wght@500;700&display=swap"
      rel="stylesheet"
    />

    <style>
      :root{
        --bg:#07111f;
        --bg-deep:#030712;
        --surface:rgba(6,18,36,0.62);
        --surface-strong:rgba(8,24,46,0.82);
        --line:rgba(120,220,255,0.22);
        --text:#f4fbff;
        --muted:#9cb4ca;
        --cyan:#8bf7ff;
        --teal:#39d5c7;
        --amber:#ffd36e;
        --shadow:0 24px 80px rgba(0,0,0,0.45);
      }

      *{
        box-sizing:border-box;
      }

      html{
        scroll-behavior:smooth;
      }

      body{
        margin:0;
        font-family:"Inter",sans-serif;
        color:var(--text);
        background:
          radial-gradient(circle at top left, rgba(57,213,199,0.18), transparent 30%),
          radial-gradient(circle at 82% 18%, rgba(255,211,110,0.16), transparent 24%),
          radial-gradient(circle at 50% 100%, rgba(139,247,255,0.12), transparent 36%),
          linear-gradient(180deg, #081424 0%, #050b15 52%, #030712 100%);
        min-height:100vh;
      }

      body::before{
        content:"";
        position:fixed;
        inset:0;
        background-image:
          linear-gradient(rgba(255,255,255,0.035) 1px, transparent 1px),
          linear-gradient(90deg, rgba(255,255,255,0.035) 1px, transparent 1px);
        background-size:44px 44px;
        mask-image:linear-gradient(180deg, rgba(255,255,255,0.45), rgba(255,255,255,0.05));
        pointer-events:none;
        opacity:0.35;
      }

      a{
        color:inherit;
        text-decoration:none;
      }

      main{
        position:relative;
        z-index:1;
      }

      .hero{
        max-width:1280px;
        margin:0 auto;
        min-height:100vh;
        padding:32px 28px 72px;
        display:grid;
        grid-template-rows:auto 1fr;
      }

      .topbar{
        display:flex;
        align-items:center;
        justify-content:space-between;
        gap:20px;
      }

      .brand{
        font-family:"Space Grotesk",sans-serif;
        font-size:15px;
        font-weight:700;
        letter-spacing:0.24em;
        text-transform:uppercase;
        color:var(--cyan);
      }

      .status{
        display:inline-flex;
        align-items:center;
        gap:10px;
        padding:10px 14px;
        border:1px solid var(--line);
        border-radius:999px;
        background:rgba(3,11,21,0.45);
        color:var(--muted);
        font-size:13px;
      }

      .status::before{
        content:"";
        width:9px;
        height:9px;
        border-radius:50%;
        background:var(--teal);
        box-shadow:0 0 16px rgba(57,213,199,0.85);
      }

      .hero-panel{
        display:grid;
        grid-template-columns:minmax(0, 1.15fr) minmax(300px, 0.85fr);
        gap:28px;
        align-items:end;
        padding-top:56px;
      }

      .hero-copy{
        position:relative;
        padding:40px 0 16px;
      }

      .eyebrow{
        display:inline-flex;
        align-items:center;
        gap:10px;
        padding:8px 14px;
        border-radius:999px;
        background:rgba(139,247,255,0.08);
        border:1px solid rgba(139,247,255,0.18);
        color:var(--cyan);
        font-size:13px;
        letter-spacing:0.08em;
        text-transform:uppercase;
      }

      .hero-copy h1{
        margin:20px 0 18px;
        font-family:"Zen Kaku Gothic New",sans-serif;
        font-size:clamp(56px, 9vw, 118px);
        line-height:0.93;
        letter-spacing:-0.05em;
      }

      .hero-copy h1 span{
        display:block;
        color:var(--amber);
      }

      .lead{
        max-width:680px;
        margin:0;
        color:var(--muted);
        font-size:clamp(16px, 2vw, 20px);
        line-height:1.9;
      }

      .hero-actions{
        display:flex;
        flex-wrap:wrap;
        gap:14px;
        margin-top:32px;
      }

      .button{
        display:inline-flex;
        align-items:center;
        justify-content:center;
        min-width:180px;
        padding:14px 22px;
        border-radius:999px;
        font-weight:700;
        transition:transform 180ms ease, box-shadow 180ms ease, background 180ms ease;
      }

      .button:hover{
        transform:translateY(-2px);
      }

      .button-primary{
        background:linear-gradient(135deg, var(--amber), #ff9d5c);
        color:#081424;
        box-shadow:0 18px 36px rgba(255,157,92,0.25);
      }

      .button-secondary{
        border:1px solid var(--line);
        background:rgba(255,255,255,0.03);
        color:var(--text);
      }

      .hero-meta{
        display:grid;
        grid-template-columns:repeat(3, minmax(0, 1fr));
        gap:14px;
        margin-top:34px;
        max-width:760px;
      }

      .meta-card{
        padding:18px 18px 16px;
        border-radius:22px;
        background:rgba(255,255,255,0.03);
        border:1px solid rgba(255,255,255,0.08);
        backdrop-filter:blur(18px);
      }

      .meta-label{
        color:var(--muted);
        font-size:12px;
        text-transform:uppercase;
        letter-spacing:0.12em;
      }

      .meta-value{
        margin-top:10px;
        font-size:26px;
        font-weight:700;
      }

      .feature-card{
        position:relative;
        overflow:hidden;
        min-height:560px;
        border-radius:32px;
        background:
          linear-gradient(180deg, rgba(4,14,28,0.15), rgba(4,14,28,0.88)),
          linear-gradient(135deg, rgba(139,247,255,0.24), rgba(255,211,110,0.1));
        border:1px solid rgba(255,255,255,0.1);
        box-shadow:var(--shadow);
        display:flex;
        align-items:flex-end;
        padding:28px;
        isolation:isolate;
      }

      .feature-card::before{
        content:"";
        position:absolute;
        inset:18px;
        border-radius:24px;
        border:1px solid rgba(255,255,255,0.08);
        pointer-events:none;
      }

      .feature-image{
        position:absolute;
        inset:0;
        width:100%;
        height:100%;
        object-fit:cover;
        z-index:-2;
      }

      .feature-glow{
        position:absolute;
        inset:auto auto 20% -8%;
        width:210px;
        height:210px;
        border-radius:50%;
        background:rgba(139,247,255,0.28);
        filter:blur(24px);
        z-index:-1;
      }

      .feature-content{
        width:100%;
        padding:22px;
        border-radius:24px;
        background:rgba(2,10,19,0.72);
        backdrop-filter:blur(18px);
        border:1px solid rgba(255,255,255,0.08);
      }

      .feature-tag{
        display:inline-block;
        color:var(--cyan);
        font-size:12px;
        letter-spacing:0.12em;
        text-transform:uppercase;
      }

      .feature-content h2{
        margin:12px 0 10px;
        font-family:"Zen Kaku Gothic New",sans-serif;
        font-size:clamp(28px, 4vw, 44px);
        line-height:1.05;
      }

      .feature-content p{
        margin:0;
        color:var(--muted);
        line-height:1.8;
      }

      .posts{
        max-width:1280px;
        margin:0 auto;
        padding:0 28px 96px;
      }

      .section-header{
        display:flex;
        align-items:end;
        justify-content:space-between;
        gap:20px;
        margin-bottom:30px;
      }

      .section-header h3{
        margin:0;
        font-family:"Space Grotesk",sans-serif;
        font-size:clamp(28px, 4vw, 46px);
      }

      .section-header p{
        margin:0;
        max-width:480px;
        color:var(--muted);
        line-height:1.8;
      }

      .grid{
        display:grid;
        grid-template-columns:repeat(auto-fit,minmax(300px,1fr));
        gap:24px;
      }

      .card{
        overflow:hidden;
        border-radius:28px;
        background:var(--surface);
        border:1px solid rgba(255,255,255,0.08);
        box-shadow:var(--shadow);
        backdrop-filter:blur(22px);
        transition:transform 180ms ease, border-color 180ms ease;
      }

      .card:hover{
        transform:translateY(-6px);
        border-color:rgba(139,247,255,0.24);
      }

      .card img{
        display:block;
        width:100%;
        height:240px;
        object-fit:cover;
      }

      .content{
        padding:24px;
      }

      .content h4{
        margin:0 0 14px;
        font-family:"Zen Kaku Gothic New",sans-serif;
        font-size:28px;
        line-height:1.2;
      }

      .portable{
        color:var(--muted);
        line-height:1.9;
      }

      .portable :global(p){
        margin:0 0 14px;
      }

      .portable :global(img){
        width:100%;
        height:auto;
        margin:22px 0;
        border-radius:18px;
      }

      @media (max-width: 960px){
        .hero{
          min-height:auto;
          padding-bottom:56px;
        }

        .hero-panel{
          grid-template-columns:1fr;
          align-items:start;
        }

        .feature-card{
          min-height:420px;
        }

        .hero-meta{
          grid-template-columns:1fr;
          max-width:none;
        }

        .section-header{
          flex-direction:column;
          align-items:start;
        }
      }

      @media (max-width: 640px){
        .hero{
          padding:20px 18px 48px;
        }

        .posts{
          padding:0 18px 72px;
        }

        .topbar{
          flex-direction:column;
          align-items:flex-start;
        }

        .feature-card{
          padding:18px;
          border-radius:26px;
        }

        .feature-content,
        .content{
          padding:20px;
        }

        .button{
          width:100%;
        }
      }
    </style>
  </head>

  <body>
    <main>
      <section class="hero">
        <div class="topbar">
          <a href="#" class="brand">Cyber Blog</a>
          <div class="status">Creative feed from Sanity CMS</div>
        </div>

        <div class="hero-panel">
          <div class="hero-copy">
            <div class="eyebrow">Main Visual / Editorial Portal</div>
            <h1>
              記事を読む前に
              <span>空気感で引き込む。</span>
            </h1>
            <p class="lead">
              サイバーな質感をベースに、トップで世界観を一気に伝えるメインビジュアルです。
              情報を並べるだけではなく、最初の一画面でサイトの温度と更新感が伝わる構成にしています。
            </p>

            <div class="hero-actions">
              <a class="button button-primary" href="#posts">最新記事を見る</a>
              <a class="button button-secondary" href="#featured">ピックアップへ</a>
            </div>

            <div class="hero-meta">
              <div class="meta-card">
                <div class="meta-label">Mood</div>
                <div class="meta-value">Cinematic</div>
              </div>
              <div class="meta-card">
                <div class="meta-label">Tone</div>
                <div class="meta-value">Cyber / Warm</div>
              </div>
              <div class="meta-card">
                <div class="meta-label">Posts</div>
                <div class="meta-value">{posts.length}</div>
              </div>
            </div>
          </div>

          <div class="feature-card" id="featured">
            {featuredPost?.mainImage && (
              <img
                class="feature-image"
                src={urlFor(featuredPost.mainImage).width(1400).height(1400).url()}
                alt={featuredPost.title}
              />
            )}
            <div class="feature-glow"></div>
            <div class="feature-content">
              <div class="feature-tag">Featured Post</div>
              <h2>{featuredPost?.title ?? "最新記事を準備中です"}</h2>
              <p>
                {featuredPost
                  ? "右側には最新記事を重ね、メインビジュアル自体が更新導線として機能するようにしています。"
                  : "記事が追加されると、ここにビジュアル付きのピックアップが表示されます。"}
              </p>
            </div>
          </div>
        </div>
      </section>

      <section class="posts" id="posts">
        <div class="section-header">
          <h3>Latest Stories</h3>
          <p>
            投稿カードの前に大きな一画面を置くことで、一覧に入る前の印象を強めています。
          </p>
        </div>

        <div class="grid">
          {posts.map((p) => (
            <article class="card">
              {p.mainImage && (
                <img src={urlFor(p.mainImage).width(900).height(640).url()} alt={p.title} />
              )}

              <div class="content">
                <h4>{p.title}</h4>
                <div class="portable">
                  <PortableText value={p.body} components={portableTextComponents} />
                </div>
              </div>
            </article>
          ))}
        </div>
      </section>
    </main>
  </body>
</html>
