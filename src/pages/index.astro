---
import { client } from "../lib/sanityClient";
const posts = await client.fetch(`
 *[_type == "post" && defined(title)]
 | order(_createdAt desc)
 { _id, title }
`);
---
<html lang="ja">
<head>
<meta charset="utf-8" />
<title>Sanity + Astro</title>
</head>
<body>
<h1>Posts</h1>
<ul>
     {posts.map((p) => <li>{p.title}</li>)}
</ul>
</body>
</html>