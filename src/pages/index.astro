---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/sections/Hero.astro";
import NewsListSection from "../components/sections/NewsListSection.astro";
import CTASection from "../components/sections/CTASection.astro";
import DepartmentCard from "../components/cards/DepartmentCard.astro";
import DoctorCard from "../components/cards/DoctorCard.astro";
import { fetchDepartments, fetchDoctors, fetchNewsPosts } from "../lib/sanity/fetchers";

const [posts, departments, doctors] = await Promise.all([
  fetchNewsPosts(),
  fetchDepartments(),
  fetchDoctors(),
]);
---

<BaseLayout path="/">
  <Hero featuredPost={posts[0]} departments={departments} doctors={doctors} />

  <section class="page-section">
    <div class="container">
      <div class="section-header">
        <div>
          <div class="eyebrow">Departments</div>
          <h2>診療科案内</h2>
        </div>
        <p>カテゴリ情報を診療科として再編し、各診療科に紐づくお知らせも一覧できる構成にしています。</p>
      </div>

      <div class="grid-3">
        {departments.slice(0, 3).map((department) => <DepartmentCard department={department} />)}
      </div>
    </div>
  </section>

  <NewsListSection posts={posts.slice(0, 3)} />

  <section class="page-section">
    <div class="container">
      <div class="section-header">
        <div>
          <div class="eyebrow">Doctors</div>
          <h2>医師紹介</h2>
        </div>
        <p>Sanity の `author` を医師情報として扱い、専門領域や関連情報が見つかりやすいレイアウトにしています。</p>
      </div>

      <div class="grid-3">
        {doctors.slice(0, 3).map((doctor) => <DoctorCard doctor={doctor} />)}
      </div>
    </div>
  </section>

  <CTASection
    title="受診や採用に関するご相談を整理した導線で案内します。"
    body="トップに情報を詰め込みすぎず、詳細ページへ自然に流せる構造です。更新運用と案内性の両立を前提にしています。"
    primaryHref="/contact"
    primaryLabel="お問い合わせ"
    secondaryHref="/recruit/"
    secondaryLabel="採用情報"
  />
</BaseLayout>
